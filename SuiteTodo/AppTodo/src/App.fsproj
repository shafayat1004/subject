<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <LangVersion>8.0</LangVersion>
    <Configurations>Web Debug;Web Release;Native Debug;Native Release</Configurations>
    <DefineConstants>FABLE_COMPILER</DefineConstants>
    <DefineConstants Condition="'$(Configuration)' == 'Web Debug' Or '$(Configuration)' == 'Native Debug'">$(DefineConstants);DEBUG</DefineConstants>
    <DefineConstants Condition="'$(Configuration)' == 'Web Debug' Or '$(Configuration)' == 'Web Release'">$(DefineConstants);EGGSHELL_PLATFORM_IS_WEB</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../../LibLangFsharp/src/LibLangFsharp.fsproj" />
    <ProjectReference Include="../../../LibLifeCycleTypes/src/LibLifeCycleTypes.fsproj" />
    <ProjectReference Include="../../../LibClient/src/LibClient.fsproj" />
    <ProjectReference Include="../../../LibRouter/src/LibRouter.fsproj" />
    <ProjectReference Include="../../../Meta/FablePlugins/FablePlugins.fsproj" />
    <ProjectReference Include="../../../LibUiSubject/src/LibUiSubject.fsproj" />
    <ProjectReference Include="../../Ecosystem/Todo.Types/Todo.Types.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="**/*.fsproj" />
  </ItemGroup>

  <!-- Foundation: app configuration and entry wiring. -->
  <ItemGroup>
    <Compile Include="Config.fs" />
    <Compile Include="RenderHelpers.fs" />
  </ItemGroup>

  <!-- Domain: error display, todo actions, queries, and display helpers. -->
  <ItemGroup>
    <Compile Include="Domain/ErrorMessages.fs" />
  </ItemGroup>

  <!-- Foundation (services + routing): may depend on Domain + FakeData. -->
  <ItemGroup>
    <Compile Include="FakeData/FakeTodoService.fs" />
    <Compile Include="Services.fs" />
    <Compile Include="Navigation.fs" />
  </ItemGroup>

  <!-- Theme: palette and component styling. -->
  <ItemGroup>
    <Compile Include="Theme/Colors.fs" />
    <Compile Include="Theme/TodoTheme.fs" />
  </ItemGroup>

  <!-- Platform registration. -->
  <ItemGroup>
    <Compile Include="Icons.fs" />
    <Compile Include="LocalImagesRegistration.fs" />
  </ItemGroup>

  <!-- Domain logic (depends on services + theme). -->
  <ItemGroup>
    <Compile Include="Domain/Actions.fs" />
    <Compile Include="Domain/TodoQueries.fs" />
    <Compile Include="Domain/TodoDisplay.fs" />
  </ItemGroup>

  <!-- Theme application (depends on Domain types). -->
  <ItemGroup>
    <Compile Include="Theme/ComponentsTheme.fs" />
    <Compile Include="ComponentsHierarchy.fs" />
  </ItemGroup>

  <!-- Components: route screens and shared UI. -->
  <ItemGroup>
    <Compile Include="Components/Route/Todos.fs" />
    <Compile Include="Components/AppContext.fs" />
    <Compile Include="Components/App.fs" />
  </ItemGroup>

  <!-- Bootstrap: registers libraries and mounts the app (last). -->
  <ItemGroup>
    <Compile Include="Bootstrap.fs" />
  </ItemGroup>
</Project>
