npm install
npm link react-templates-fable
npm link ../../LibClient/node_modules/react

# Android debug keystore (standard RN debug signing)
if [ ! -f android/app/debug.keystore ]; then
  keytool -genkeypair -v \
    -keystore android/app/debug.keystore \
    -storepass android \
    -alias androiddebugkey \
    -keypass android \
    -keyalg RSA \
    -keysize 2048 \
    -validity 10000 \
    -dname "CN=Android Debug,O=Android,C=US"
fi

# deleting for idempotency
