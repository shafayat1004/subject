module Components.TestRender

module FRH = Fable.React.Helpers
module FRP = Fable.React.Props
module FRS = Fable.React.Standard

open LibClient.RenderResultModule

open Components



open Components.Test



let render(props: Components.Test.Props, estate: Components.Test.Estate, pstate: Components.Test.Pstate, actions: Components.Test.Actions, __componentStyles: Rn.Styles.RuntimeStyles) : Fable.React.ReactElement =
    let __class = (Rn.Helpers.extractProp "ClassName" props) |> Option.defaultValue ""
    let __mergedStyles = Rn.Styles.Runtime.mergeComponentAndPropsStyles __componentStyles props
    let __parentFQN = None
    (fun (__sibI, __sibC, __pFQN) ->
        let __parentFQN = Some "Components.div"
        Components.div.Make
            (
                let __currExplicitProps = (Components.TypeExtensions.TEs.MakedivProps())
                let __currClass = (nthChildClasses __sibI __sibC)
                let __currStyles = (Rn.Styles.Runtime.findApplicableStyles __mergedStyles __currClass)
                let __implicitProps = [
                    if __currClass <> "" then ("ClassName", __currClass :> obj)
                    if (not __currStyles.IsEmpty) then ("__style", __currStyles :> obj)
                ]
                (Rn.Styles.Runtime.injectImplicitProps __implicitProps __currExplicitProps)
            )
            (
                let __list = [
                    (
                        ([1;2;3])
                        |> Seq.map
                            (fun i ->
                                (fun (__sibI, __sibC, __pFQN) ->
                                    let __parentFQN = Some "Components.div"
                                    Components.div.Make
                                        (
                                            let __currExplicitProps = (Components.TypeExtensions.TEs.MakedivProps())
                                            let __currClass = (nthChildClasses __sibI __sibC)
                                            let __currStyles = (Rn.Styles.Runtime.findApplicableStyles __mergedStyles __currClass)
                                            let __implicitProps = [
                                                if __currClass <> "" then ("ClassName", __currClass :> obj)
                                                if (not __currStyles.IsEmpty) then ("__style", __currStyles :> obj)
                                            ]
                                            (Rn.Styles.Runtime.injectImplicitProps __implicitProps __currExplicitProps)
                                        )
                                        (
                                            let bar = (
                                                FRH.fragment []
                                                    (
                                                        let __list = [
                                                            (fun (__sibI, __sibC, __pFQN) ->
                                                                let __parentFQN = Some "Components.div"
                                                                Components.div.Make
                                                                    (
                                                                        let __currExplicitProps = (Components.TypeExtensions.TEs.MakedivProps())
                                                                        let __currClass = (nthChildClasses __sibI __sibC)
                                                                        let __currStyles = (Rn.Styles.Runtime.findApplicableStyles __mergedStyles __currClass)
                                                                        let __implicitProps = [
                                                                            if __currClass <> "" then ("ClassName", __currClass :> obj)
                                                                            if (not __currStyles.IsEmpty) then ("__style", __currStyles :> obj)
                                                                        ]
                                                                        (Rn.Styles.Runtime.injectImplicitProps __implicitProps __currExplicitProps)
                                                                    )
                                                                    (
                                                                        let __list = [
                                                                            ((makeTextNode "The Bar") |> RenderResult.Make)
                                                                        ]
                                                                        __list |> RenderResult.ToRawElements __parentFQN
                                                                    )
                                                            ) |> RenderResult.Make
                                                        ]
                                                        __list |> RenderResult.ToRawElements __parentFQN
                                                    )
                                            )
                                            let foo = (
                                                FRH.fragment []
                                                    (
                                                        let __list = [
                                                            (fun (__sibI, __sibC, __pFQN) ->
                                                                let __parentFQN = Some "Components.div"
                                                                Components.div.Make
                                                                    (
                                                                        let __currExplicitProps = (Components.TypeExtensions.TEs.MakedivProps())
                                                                        let __currClass = (nthChildClasses __sibI __sibC)
                                                                        let __currStyles = (Rn.Styles.Runtime.findApplicableStyles __mergedStyles __currClass)
                                                                        let __implicitProps = [
                                                                            if __currClass <> "" then ("ClassName", __currClass :> obj)
                                                                            if (not __currStyles.IsEmpty) then ("__style", __currStyles :> obj)
                                                                        ]
                                                                        (Rn.Styles.Runtime.injectImplicitProps __implicitProps __currExplicitProps)
                                                                    )
                                                                    (
                                                                        let __list = [
                                                                            ((makeTextNode "The Foo") |> RenderResult.Make)
                                                                        ]
                                                                        __list |> RenderResult.ToRawElements __parentFQN
                                                                    )
                                                            ) |> RenderResult.Make
                                                        ]
                                                        __list |> RenderResult.ToRawElements __parentFQN
                                                    )
                                            )
                                            let __list = [
                                                (fun (__sibI, __sibC, __pFQN) ->
                                                    let __parentFQN = Some "Components.div"
                                                    Components.div.Make
                                                        (
                                                            let __currExplicitProps = (Components.TypeExtensions.TEs.MakedivProps())
                                                            let __currClass = (nthChildClasses __sibI __sibC)
                                                            let __currStyles = (Rn.Styles.Runtime.findApplicableStyles __mergedStyles __currClass)
                                                            let __implicitProps = [
                                                                if __currClass <> "" then ("ClassName", __currClass :> obj)
                                                                if (not __currStyles.IsEmpty) then ("__style", __currStyles :> obj)
                                                            ]
                                                            (Rn.Styles.Runtime.injectImplicitProps __implicitProps __currExplicitProps)
                                                        )
                                                        (
                                                            let __list = [
                                                                (fun (__sibI, __sibC, __pFQN) ->
                                                                    let __parentFQN = Some "Components.div"
                                                                    Components.div.Make
                                                                        (
                                                                            let __currExplicitProps = (Components.TypeExtensions.TEs.MakedivProps())
                                                                            let __currClass = (nthChildClasses __sibI __sibC)
                                                                            let __currStyles = (Rn.Styles.Runtime.findApplicableStyles __mergedStyles __currClass)
                                                                            let __implicitProps = [
                                                                                if __currClass <> "" then ("ClassName", __currClass :> obj)
                                                                                if (not __currStyles.IsEmpty) then ("__style", __currStyles :> obj)
                                                                            ]
                                                                            (Rn.Styles.Runtime.injectImplicitProps __implicitProps __currExplicitProps)
                                                                        )
                                                                        (
                                                                            let __list = [
                                                                                ((foo) |> RenderResult.Make)
                                                                            ]
                                                                            __list |> RenderResult.ToRawElements __parentFQN
                                                                        )
                                                                ) |> RenderResult.Make
                                                                ((bar) |> RenderResult.Make)
                                                            ]
                                                            __list |> RenderResult.ToRawElements __parentFQN
                                                        )
                                                ) |> RenderResult.Make
                                            ]
                                            __list |> RenderResult.ToRawElements __parentFQN
                                        )
                                ) |> RenderResult.Make
                            )
                        |> List.ofSeq
                        |> RenderResult.Make
                    )
                ]
                __list |> RenderResult.ToRawElements __parentFQN
            )
    ) |> RenderResult.Make
    |> RenderResult.ToRawElementsSingle __parentFQN |> RenderResult.ToSingleElement