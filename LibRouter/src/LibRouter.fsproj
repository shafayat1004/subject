<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <LangVersion>8.0</LangVersion>
    <Configurations>Web Debug;Web Release;Native Debug;Native Release</Configurations>
    <DefineConstants>FABLE_COMPILER</DefineConstants>
    <DefineConstants Condition="'$(Configuration)' == 'Web Debug' Or '$(Configuration)' == 'Native Debug'">$(DefineConstants);DEBUG</DefineConstants>
    <DefineConstants Condition="'$(Configuration)' == 'Web Debug' Or '$(Configuration)' == 'Web Release'">$(DefineConstants);EGGSHELL_PLATFORM_IS_WEB</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="**/*.fsproj" />
    <Content Include="**/*.render" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../LibLangFsharp/src/LibLangFsharp.fsproj" />
    <ProjectReference Include="../../LibClient/src/LibClient.fsproj" />

    <Compile Include="ComponentsHierarchy.fs" />
    <Compile Include="RoutesSpec.fs" />
  </ItemGroup>

  <ItemGroup>

    <Compile Include="Components/Router/Router.typext.fs" />
    <Compile Include="_autogenerated_/Components/Router/Router.TypeExtensions.fs" />

    <Compile Include="Components/NativeBackButton/NativeBackButton.fs" />
    <Compile Include="Components/NativeBackButton/EdgeSwipeBack.fs" />

    <Compile Include="Components/With/Location/Location.fs" />

    <Compile Include="Components/Route.fs" />

    <Compile Include="Components/Link/Link.typext.fs" />
    <Compile Include="_autogenerated_/Components/Link/Link.TypeExtensions.fs" />

    <Compile Include="Components/With/Route/Route.fs" />

    <Compile Include="Components/With/CurrentRoute.fs" />

    <Compile Include="Components/With/Navigation/Navigation.fs" />

    <Compile Include="Components/NavigationRouter.fs" />

    <Compile Include="Components/With/Navigation/NavigationBridge.fs" />

    <Compile Include="Components/Legacy/TopNav/BackButton.fs" />

    <Compile Include="Components/Dialogs/Dialogs.fs" />

    <Compile Include="Components/Nav/BackButton.fs" />

    <Compile Include="Components/LogRouteTransitions/LogRouteTransitions.fs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="ButtonHighLevelStateFactoryTypeExtensions.fs" />
    <Compile Include="ComponentRegistration.fs" />
    <Compile Include="DefaultComponentsTheme.fs" />
    <Compile Include="Wrappers.fs" />
    <Compile Include="App.fs" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Components\Nav\Top\" />
  </ItemGroup>
</Project>
