# Android/IntelliJ
#
build/
.idea
.gradle
local.properties
*.iml
*.hprof
.cxx/

android/app/my-upload-key
android/app/my-upload-key.keystore

# node.js
#
node_modules/
npm-debug.log
yarn-error.log

# BUCK
buck-out/
\.buckd/
*.keystore
!debug.keystore


# contains secrets like API keys and the like, only template included in the repo
configSourceOverrides.native.js

# --- iOS (React Native) ---
ios/Pods/
ios/build/
ios/DerivedData/
ios/build_derived/
ios/.xcode.env.local
ios/**/*.xcuserstate
ios/**/xcuserdata/
# Per-developer signing: ios/Config.xcconfig is committed and #include?s this local,
# never-committed file (see ios/Config.xcconfig). Never commit a personal DEVELOPMENT_TEAM.
ios/**/Local.xcconfig
*.mobileprovision

# Fable native dev emits JS beside .fs sources (Metro uses .build/native/commonjs/ instead)
**/*.fs.js

# Generated by scripts/gen-docs-bundle.js (via metro.config.js) -- bundled docs for native.
src/DocsContent.generated.js

# Android gallery audit output
audit-android/interactive/
audit-android/local/

# Playwright gallery audit output
audit-browser/interactive/
audit-browser/local/
audit-browser/prod/
audit-browser/interactive-latest-run.log
audit-browser/summary.json
console-errors-*.txt
.tmp-gallery-browser-test.mjs

# Ignore copied assets
public-dev/images/
public-dev/libs/
