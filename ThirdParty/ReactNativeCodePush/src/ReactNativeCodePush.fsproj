<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>8.0</LangVersion>
    <Configurations>Fable Debug;Fable Release</Configurations>
    <DefineConstants>FABLE_COMPILER</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="**/*.fsproj" />
    <Content Include="**/*.render" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../LibLangFsharp/src/LibLangFsharp.fsproj" />
    <ProjectReference Include="../../../LibClient/src/LibClient.fsproj" />

    <Compile Include="ComponentsHierarchy.fs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Components/ReactNativeCodePush/ReactNativeCodePush.fs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="ComponentRegistration.fs" />
  </ItemGroup>
</Project>
