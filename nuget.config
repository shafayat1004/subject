<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local feed for repo-internal dotnet tools (e.g. EggShellFmt).
         Populated by Meta/EggShellFmt/install.sh; the nupkg itself is git-ignored. -->
    <add key="eggshell-local" value="Meta/EggShellFmt/nupkg" />
    <!--
    Include internal NuGet feed as a source.

    NOTE: To connect to the Azure NuGet feed, you will need to perform a one-time setup of the Azure Artifacts Credential Provider.
          See https://github.com/microsoft/artifacts-credprovider#azure-artifacts-credential-provider.
    -->
  </packageSources>
</configuration>