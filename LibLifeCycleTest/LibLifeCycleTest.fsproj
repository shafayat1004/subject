<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>8.0</LangVersion>
	<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
	<!-- FS0044: pre-existing net10 obsolescence warnings (obsolete formatter serialization).
	     Suppressed until each API is migrated. -->
	<NoWarn>FS0044</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="Autofac" Version="8.3.0" />
    <PackageReference Include="xunit" Version="2.9.0" />
    <PackageReference Include="FsUnit.xUnit" Version="6.0.1" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="coverlet.collector" Version="6.0.2" />
    <!-- ADI >= 9.0.0 is required for .NET 8 keyed-services support; Orleans 10 registers keyed
         services, and the old 6.0.0 crashed silo boot with RegisterInstance(null) -> ArgumentNullException
         (autofac/Autofac.Extensions.DependencyInjection #112/#116). See modernization/spikes/s15c-closure-codegen.md. -->
    <PackageReference Include="Autofac.Extensions.DependencyInjection" Version="10.0.0" />
    <PackageReference Update="FSharp.Core" VersionOverride="10.0.103" />
    <PackageReference Include="Microsoft.Orleans.TestingHost" Version="10.2.1" />
    <PackageReference Include="Microsoft.Orleans.Sdk" Version="10.2.1" />
    <PackageReference Include="FsCheck.Xunit" Version="2.16.6" />
    <PackageReference Include="ShellProgressBar" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../LibLifeCycleHostBuild/LibLifeCycleHostBuild.csproj" />
    <ProjectReference Include="../LibLangFsharp/src/LibLangFsharp.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Operators.fs" />
    <Compile Include="AssertExtensions.fs" />
    <Compile Include="UnionCaseTests.fs" />
    <Compile Include="TypeTests.fs" />
    <Compile Include="CertificateTests.fs" />
    <Compile Include="ClientGrainCallContextCodecTests.fs" />
    <Compile Include="IndexQueryOptimizerTests.fs" />
    <Compile Include="CookieDomainTests.fs" />
    <Compile Include="Gen\Common.fs" />
    <Compile Include="Gen\GenExtensions.fs" />
    <Compile Include="Gen\Strings.fs" />
    <Compile Include="Gen\PhoneNumber.fs" />
    <Compile Include="Gen\Date.fs" />
    <Compile Include="ClockSimulation.fs" />
    <Compile Include="SideEffectTracking.fs" />
    <Compile Include="Cluster.fs" />
    <Compile Include="TestApplicationInsights.fs" />
    <Compile Include="TestCluster.fs" />
    <Compile Include="Random.fs" />
    <Compile Include="Attributes.fs" />
    <Compile Include="SimulationBuilder.fs" />
    <Compile Include="DataSeeding/SimulationDiscovery.fs" />
    <Compile Include="DataSeeding/SimulationExecution.fs" />
    <Compile Include="DataSeeding/EntryPoint.fs" />
    <Compile Include="TestRunner.fs" />
    <Compile Include="Ecosystem.fs" />
    <Compile Include="LibLangFsharp/OrderedSetTests.fs" />
    <Compile Include="LibLangFsharp\EncodedPolylineTests.fs" />
    <Content Include="..\LibLifeCycleHost\src\Host\Development\appsettings.json" Link="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
